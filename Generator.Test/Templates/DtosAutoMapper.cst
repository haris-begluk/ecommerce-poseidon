{ 

@:    public partial class @(model.Name)Dto : IMapFrom<@(model.Name)>
@:    { 
var maxPropLength = ((IEnumerable<Field>)model.Fields).Select(x => x.PropertyName.Length).Max();
var maxTypeLength = ((IEnumerable<Field>)model.Fields).Select(x => GeneratorTemplate.GetDataType(x).Length).Max();

foreach (var field in model.Fields)
{ 
          var dataType = GeneratorTemplate.GetDataType(field);
@:        public @(dataType) @(GetSpaces(maxTypeLength - dataType.Length)) @(field.PropertyName) @(GetSpaces(maxPropLength - field.PropertyName.Length))  { get; set; }
} 
@:
@:
@:
@:    public void Mapping(Profile profile)
@:    {  
@:          profile.CreateMap< @(model.Name), @(model.Name)Dto >()


foreach (var field in ((IEnumerable<Field>)model.Fields).Where(x => x.PropertyName != "Id"))
{ 
@:             .ForMember(d => d.@(field.PropertyName) @(GetSpaces(maxPropLength - field.PropertyName.Length)), opt => opt.MapFrom(s => s.@(field.PropertyName)  @(GetSpaces(maxPropLength - field.PropertyName.Length)) ))
}

@:             ;

