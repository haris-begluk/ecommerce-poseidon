@using Generator;
@using RazorLight;
@using System;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@using Generator.Test;  
@using static Generator.Test.Root 
@using System.Linq; 
/**************************************************************
* This code is generated by custom generator  
*************************************************************/
namespace Poseidon.Application.Commands;

using MediatR;
using Poseidon.Enums;
using System;


@{ 
//SAVE OR UPDATE 


foreach (var model in Model)
{ 
var type = GeneratorTemplate.GetDataType(((IEnumerable<Field>)model.Fields).First(x => x.PropertyName.Equals(model.Name+"Id"))); 
var IdType = type.Replace("?", String.Empty);

@:    public partial class @(model.Name)Command : IRequest<(@(IdType) id, Status status)>
@:    { 
var maxPropLength = ((IEnumerable<Field>)model.Fields).Select(x => x.PropertyName.Length).Max();
var maxTypeLength = ((IEnumerable<Field>)model.Fields).Select(x => GeneratorTemplate.GetDataType(x).Length).Max();

foreach (var field in ((IEnumerable<Field>) model.Fields).Where(f => !f.PropertyName.StartsWith("Sys_", StringComparison.InvariantCulture)))
{ 
          var dataType = GeneratorTemplate.GetDataType(field); 
@:        public @(dataType.Contains("?") ? dataType: dataType + "?") @(GetSpaces(maxTypeLength - dataType.Length)) @(field.PropertyName) @(GetSpaces(maxPropLength - field.PropertyName.Length))  { get; set; }
}
@:    } 


  }
}



