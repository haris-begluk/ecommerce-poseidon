@using Generator;
@using RazorLight;
@using System;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@using Generator.Test;  
@using static Generator.Test.Root 
@using System.Linq; 
/**************************************************************
* This code is generated by custom generator  
*************************************************************/
using AutoMapper;
using Poseidon.Domain;
namespace Poseidon.Application.Commands;

@{ 
foreach (var model in Model)
{ 
var maxPropLength = ((IEnumerable<Field>)model.Fields).Where(f => !f.PropertyName.StartsWith("Sys_", StringComparison.InvariantCulture)).Select(x => x.PropertyName.Length).Max();
var maxTypeLength = ((IEnumerable<Field>)model.Fields).Where(f => !f.PropertyName.StartsWith("Sys_", StringComparison.InvariantCulture)).Select(x => (GeneratorTemplate.GetDataType(x).EndsWith("?") ? GeneratorTemplate.GetDataType(x) : GeneratorTemplate.GetDataType(x) + "?").Length).Max();

@:public class @(model.Name)Command : IUpsertCommand<@(model.Name)>
@:{ 
foreach (var field in ((IEnumerable<Field>) model.Fields).Where(f => !f.PropertyName.StartsWith("Sys_", StringComparison.InvariantCulture)))
{ 
          var dataType = GeneratorTemplate.GetDataType(field);
          var nullableType = dataType.EndsWith("?") ? dataType : dataType + "?";
@:    public @(nullableType) @(GetSpaces(maxTypeLength - nullableType.Length)) @(field.PropertyName) @(GetSpaces(maxPropLength - field.PropertyName.Length))  { get; set; }
}
@:
@:    public void Mapping(Profile profile)
@:    {
@:         profile.CreateMap<@(model.Name)Command, @(model.Name)>().MapOnlyIfChanged();
@:    }
@:} 

  }
}

