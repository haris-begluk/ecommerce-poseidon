@using Generator;
@using RazorLight;
@using System;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@using Generator.Test;  
@using static Generator.Test.Root 
@using System.Linq; 
/**************************************************************
* This code is generated by custom generator  
*************************************************************/
namespace Poseidon.Endpoints;
using MediatR;
using Microsoft.AspNetCore.Builder;
using Microsoft.AspNetCore.Http;
using Microsoft.AspNetCore.Mvc;
using Poseidon.Api.Exceptions;
using Poseidon.Application.CommandHandlers;
using Poseidon.Application.Commands;
using Poseidon.Application.Dto;
using Poseidon.Application.Helpers;
using Poseidon.Application.Queries;
using Poseidon.Enums;
using System.ComponentModel;

@{ 
@:public static partial class Endpoints
@:{
foreach (var model in Model) {  
var type = GeneratorTemplate.GetDataType(((IEnumerable<Field>)model.Fields).First(x => x.PropertyName.Equals(model.Name+"Id"))); 
var IdType = type.Replace("?", String.Empty);
@:////////////////////////////////////////////////////////
@://// @(model.Name) mini api                          ///
@://////////////////////////////////////////////////////// 
@:public static void Mapp@(model.Name)(this WebApplication app)
@:{
@:    app.MapGet("mediatr/@(model.Name.ToLower())/query",
@:    [ProducesResponseType(200, Type = (typeof(ResponseData<@(model.Name)Dto>)))]
@:    [ProducesResponseType(500, Type = (typeof(ErrorResponse)))]
@:    async ([FromServices] IMediator             _mediator 
@:         , [FromQuery] [DefaultValue(1)]                         int?    page
@:         , [FromQuery] [DefaultValue(1000)]                      int?    pageSize
@:         , [FromQuery] [DefaultValue("Sys_UpdatedAt")]           string? orderBy 
@:         , [FromQuery] [DefaultValue("Sys_Deactivated != true")] string? filter
@:    ) =>
@:    { 
@:        return Results.Ok(await _mediator.Send(new @(model.Name)Query(page, pageSize, filter, orderBy)));
@:    })
@:    .RequireAuthorization();
@:    
@:    app.MapPost("mediatr/@(model.Name.ToLower())/upsert", 
@:    [ProducesResponseType(200, Type = (typeof(@(IdType))))]
@:    [ProducesResponseType(201, Type = (typeof(@(IdType))))]
@:    [ProducesResponseType(400, Type = (typeof(ErrorResponse)))]
@:    [ProducesResponseType(404, Type = (typeof(ErrorResponse)))]
@:    [ProducesResponseType(500, Type = (typeof(ErrorResponse)))]
@:    async ([FromServices] IMediator          _mediator 
@:         , [FromBody] @(model.Name)Command   command) =>
@:    {
@:        var (id, status) = await _mediator.Send(command);
@:
@:        return status is Status.Created 
@:               ? Results.Created($"mediatr/@(model.Name.ToLower())/upsert", id) 
@:               : Results.Ok(id);
@:
@:    }).RequireAuthorization();
@:
@:    app.MapDelete("mediatr/@(model.Name.ToLower())", 
@:    [ProducesResponseType(200, Type = (typeof(@(IdType))))]
@:    [ProducesResponseType(404, Type = (typeof(@(IdType))))]
@:    [ProducesResponseType(500, Type = (typeof(ErrorResponse)))]
@:    async ( [FromServices] IMediator          _mediator
@:          , [FromQuery] @(IdType) id) =>
@:    {
@:       var (_id, status) = await _mediator.Send(new Delete@(model.Name)Command { Id = id });
@:
@:       return status is Status.Deleted 
@:       ? Results.Ok(_id) 
@:       : Results.NotFound(_id);
@:    }).RequireAuthorization();
@:
@:}
} 

@:////////////////////////////////////////////////////////
@://// Mapp all endpoints                              ///
@://////////////////////////////////////////////////////// 
@:    public static void  MappEndpoints(this WebApplication app) 
@:    {
 var maxNameLength = ((IEnumerable<Model>)Model).Select(x => x.Name.Length).Max();
foreach(var model in Model)
{
@:        app.Mapp@(model.Name)@(GetSpaces(maxNameLength - model.Name.Length))();
}  
@:        app.MappCustomEndpoints();
@:    }

@:} 
}