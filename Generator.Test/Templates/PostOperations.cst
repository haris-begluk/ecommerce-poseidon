@using Generator;
@using RazorLight;
@using System;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@using Generator.Test;  
@using static Generator.Test.Root 
@using System.Linq; 
/**************************************************************
* This code is generated by custom generator  
**************************************************************/
@{
string GetSysName(string v)
{
    var parts = v.Split('_');
    return FirstLower(parts[0]) + parts[1];
}

string FirstLower(string v)
   => string.IsNullOrWhiteSpace(v) 
   ? v 
   : Char.ToLowerInvariant(v[0]) + v.Substring(1);





