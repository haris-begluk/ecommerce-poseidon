@using Generator;
@using RazorLight;
@using System;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@using Generator.Test;  
@using static Generator.Test.Root 
@using System.Linq; 
/**************************************************************
* This code is generated by custom generator  
**************************************************************/
@{
string GetSysName(string v)
{
    var parts = v.Split('_');
    return FirstLower(parts[0]) + parts[1];
}

string FirstLower(string v)
   => string.IsNullOrWhiteSpace(v) 
   ? v 
   : Char.ToLowerInvariant(v[0]) + v.Substring(1);






foreach (var model in Model)
{ 
var maxPropLength = ((IEnumerable<Field>)model.Fields).Select(x => x.PropertyName.Length).Max();
var maxTypeLength = ((IEnumerable<Field>)model.Fields).Select(x => GeneratorTemplate.GetDataType(x).Length).Max();

@:    class @(model.Name) extends @(model.Name)Dto with ChangeNotifier
@:    { 
@:          @(model.Name)( @(model.Name)Dto dto): super(
foreach (var field in model.Fields)
{  

var name = field.PropertyName.StartsWith("Sys", StringComparison.OrdinalIgnoreCase)
            ? GetSysName(field.PropertyName) 
            : FirstLower(field.PropertyName);

@:              @(name) : dto.@(name),
} 
@:              );
@:    }
  }
}
